<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/lockScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/diaryLockBackground"
    android:visibility="gone">

    <com.google.android.material.card.MaterialCardView
        style="?attr/diaryLockCardStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="36dp"
            android:paddingBottom="28dp">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/diaryLockEmojiCircle" />

                <TextView
                    android:id="@+id/lockEmojiText"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="☀️"
                    android:textSize="44sp" />

            </FrameLayout>

            <TextView
                android:id="@+id/lockTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.03"
                android:text="@string/app_locked_title"
                android:textColor="?attr/diaryLockTitleColor"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lockMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/app_locked_message"
                android:textColor="?attr/diaryLockSubtitleColor"
                android:textSize="15sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="?attr/diaryLockInputStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:endIconMode="password_toggle"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/lockPasswordInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/lock_password_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textPassword"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:textSize="15sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnlock"
                style="?attr/diaryLockButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/unlock" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForgotPassword"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/forgot_password"
                android:textColor="?attr/diaryLockSubtitleColor" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
